# ── Meta Ads API ──────────────────────────────────────────────
META_ACCESS_TOKEN=your_long_lived_access_token_here
META_AD_ACCOUNT_ID=act_XXXXXXXXXX
META_PAGE_ID=your_page_id_here
META_IG_ACCOUNT_ID=your_instagram_business_account_id_here
META_API_VERSION=v21.0

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=-100XXXXXXXXXX
TELEGRAM_PERSONAL_CHAT_ID=XXXXXXXXXX

# ── Google Sheets & Drive ─────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_CREDENTIALS_FILE=/path/to/service-account.json
DRIVE_STAT_FOLDER_ID=your_google_drive_folder_id

# ── AI (optional) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
